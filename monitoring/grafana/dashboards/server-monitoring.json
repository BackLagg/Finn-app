    {
      "id": 14,
      "title": "Disk Operations",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total{instance=~\"$instance\", device!~\"loop.*|ram.*|md.*|dm-.*\"}[5m])",
          "legendFormat": "{{device}} - Reads/sec"
        },
        {
          "expr": "rate(node_disk_writes_completed_total{instance=~\"$instance\", device!~\"loop.*|ram.*|md.*|dm-.*\"}[5m])",
          "legendFormat": "{{device}} - Writes/sec"
