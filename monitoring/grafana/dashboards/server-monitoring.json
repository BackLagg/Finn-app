            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 12,
      "title": "💾 Disk Metrics",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "panels": []
    },
    {
      "id": 13,
      "title": "Disk I/O",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\", device!~\"loop.*|ram.*|md.*|dm-.*\"}[5m])",
          "legendFormat": "{{device}} - Read"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=~\"$instance\", device!~\"loop.*|ram.*|md.*|dm-.*\"}[5m])",
          "legendFormat": "{{device}} - Write"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
