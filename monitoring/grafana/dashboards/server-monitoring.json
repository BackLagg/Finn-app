        }
      }
    },
    {
      "id": 15,
      "title": "🔧 System Information",
      "type": "row",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33},
      "panels": []
    },
    {
      "id": 16,
      "title": "System Info",
      "type": "table",
      "targets": [
        {
          "expr": "node_uname_info{instance=~\"$instance\"}",
          "legendFormat": "{{domainname}} {{machine}} {{nodename}} {{release}} {{sysname}} {{version}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "mappings": []
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37},
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 17,
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "node_boot_time_seconds{instance=~\"$instance\"}",
          "legendFormat": "Boot Time"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "displayMode": "list"
          },
          "mappings": [],
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 37},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 18,
      "title": "Temperature",
      "type": "stat",
      "targets": [
        {
          "expr": "node_hwmon_temp_celsius{instance=~\"$instance\"}",
          "legendFormat": "{{chip}} {{sensor}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "#299c46", "value": null},
              {"color": "#f5c518", "value": 60},
              {"color": "#e02f44", "value": 80}
            ]
          },
          "unit": "celsius",
          "mappings": []
        }
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 37},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
